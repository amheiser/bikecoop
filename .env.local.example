# Copy to .env.local and fill in real values.
AUTH_USERNAME=coop
AUTH_PASSWORD=change-me
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string
# Optional; defaults to ./bikecoop.db. Production (Render): /var/data/bikecoop.db
# DATABASE_PATH=./bikecoop.db

# Lapsed-member renewal emails (Resend). Leave unset for dry-run mode:
# the queue/log work fully, but emails are logged to the console, not sent.
# RESEND_API_KEY=re_...
# EMAIL_FROM="St. Pete Bike Coop <members@example.org>"
